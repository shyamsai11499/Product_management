<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ShopVault — Affiliate Store</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0a0f;
    --surface: #13131a;
    --card: #1a1a25;
    --border: #2a2a3a;
    --accent: #ff6b35;
    --accent2: #ffd700;
    --text: #f0f0f5;
    --muted: #888899;
    --success: #4ade80;
    --danger: #f87171;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body { background:var(--bg); color:var(--text); font-family:'DM Sans',sans-serif; min-height:100vh; }

  /* ── PAGE MANAGEMENT ── */
  .page { display:none; }
  .page.active { display:block; }

  /* ── HEADER ── */
  header {
    position:sticky; top:0; z-index:100;
    background:rgba(10,10,15,0.85); backdrop-filter:blur(16px);
    border-bottom:1px solid var(--border);
    padding:0 2rem;
    display:flex; align-items:center; justify-content:space-between;
    height:64px;
  }
  .logo {
    font-family:'Syne',sans-serif; font-weight:800; font-size:1.4rem;
    display:flex; align-items:center; gap:.5rem;
  }
  .logo span { color:var(--accent); }
  .logo-icon { font-size:1.6rem; }

  /* ── HERO ── */
  .hero {
    text-align:center; padding:5rem 2rem 3rem;
    background: radial-gradient(ellipse 80% 50% at 50% -10%, rgba(255,107,53,.18) 0%, transparent 70%);
  }
  .hero h1 { font-family:'Syne',sans-serif; font-size:clamp(2rem,5vw,3.5rem); font-weight:800; line-height:1.1; }
  .hero h1 em { color:var(--accent); font-style:normal; }
  .hero p { color:var(--muted); margin-top:.8rem; font-size:1.05rem; }

  /* ── PRODUCT GRID ── */
  .grid-wrap { padding:2rem; max-width:1200px; margin:0 auto; }
  .products-grid {
    display:grid;
    grid-template-columns:repeat(auto-fill, minmax(260px, 1fr));
    gap:1.5rem;
  }
  .empty-state {
    text-align:center; padding:4rem 2rem; color:var(--muted);
    grid-column:1/-1;
  }
  .empty-state .big { font-size:3rem; margin-bottom:.8rem; }

  /* ── PRODUCT CARD ── */
  .product-card {
    background:var(--card); border:1px solid var(--border); border-radius:16px;
    overflow:hidden; display:flex; flex-direction:column;
    transition:transform .25s, box-shadow .25s;
    position:relative;
  }
  .product-card:hover { transform:translateY(-4px); box-shadow:0 12px 40px rgba(255,107,53,.15); }
  .product-img-wrap { position:relative; height:200px; overflow:hidden; background:#111; }
  .product-img-wrap img { width:100%; height:100%; object-fit:cover; transition:transform .4s; }
  .product-card:hover .product-img-wrap img { transform:scale(1.05); }
  .no-img {
    width:100%; height:100%; display:flex; flex-direction:column;
    align-items:center; justify-content:center; color:var(--muted); gap:.4rem;
    font-size:.85rem;
  }
  .no-img .icon { font-size:2.5rem; }
  .product-body { padding:1.2rem; flex:1; display:flex; flex-direction:column; gap:.8rem; }
  .product-name { font-family:'Syne',sans-serif; font-weight:700; font-size:1.05rem; line-height:1.3; }
  .product-desc { color:var(--muted); font-size:.88rem; line-height:1.5; flex:1; }
  .btn-open {
    display:block; text-align:center; text-decoration:none;
    background:var(--accent); color:#fff; font-family:'Syne',sans-serif; font-weight:700;
    padding:.7rem 1rem; border-radius:10px; border:none; cursor:pointer;
    font-size:.9rem; letter-spacing:.03em; transition:background .2s, transform .15s;
    margin-top:auto;
  }
  .btn-open:hover { background:#ff8554; transform:scale(1.02); }

  /* ── LOGIN SECTION ── */
  .login-section {
    border-top:1px solid var(--border);
    padding:4rem 2rem;
    display:flex; flex-direction:column; align-items:center; gap:.8rem;
    background: linear-gradient(to bottom, transparent, rgba(255,107,53,.04));
  }
  .login-section p { color:var(--muted); font-size:.9rem; }
  .btn-login-toggle {
    background:transparent; border:1px solid var(--border);
    color:var(--muted); padding:.55rem 1.4rem; border-radius:8px;
    cursor:pointer; font-family:'DM Sans',sans-serif; font-size:.9rem;
    transition:border-color .2s, color .2s;
  }
  .btn-login-toggle:hover { border-color:var(--accent); color:var(--accent); }

  /* ── LOGIN MODAL ── */
  .modal-overlay {
    display:none; position:fixed; inset:0;
    background:rgba(0,0,0,.75); backdrop-filter:blur(8px);
    z-index:200; align-items:center; justify-content:center;
  }
  .modal-overlay.open { display:flex; }
  .modal {
    background:var(--surface); border:1px solid var(--border); border-radius:20px;
    padding:2.5rem; width:min(420px,90vw);
    animation:slideUp .3s ease;
  }
  @keyframes slideUp { from{transform:translateY(20px);opacity:0} to{transform:translateY(0);opacity:1} }
  .modal h2 { font-family:'Syne',sans-serif; font-weight:800; font-size:1.4rem; margin-bottom:1.5rem; }
  .modal h2 span { color:var(--accent); }
  .field { display:flex; flex-direction:column; gap:.4rem; margin-bottom:1rem; }
  .field label { font-size:.8rem; color:var(--muted); letter-spacing:.06em; text-transform:uppercase; }
  .field input, .field textarea, .field select {
    background:var(--card); border:1px solid var(--border); color:var(--text);
    padding:.7rem 1rem; border-radius:10px; font-family:'DM Sans',sans-serif; font-size:.95rem;
    outline:none; transition:border-color .2s;
  }
  .field input:focus, .field textarea:focus { border-color:var(--accent); }
  .field textarea { resize:vertical; min-height:80px; }
  .btn-primary {
    width:100%; padding:.8rem; background:var(--accent); color:#fff;
    border:none; border-radius:10px; font-family:'Syne',sans-serif; font-weight:700;
    font-size:1rem; cursor:pointer; transition:background .2s;
  }
  .btn-primary:hover { background:#ff8554; }
  .btn-secondary {
    width:100%; padding:.7rem; background:transparent; color:var(--muted);
    border:1px solid var(--border); border-radius:10px; font-family:'DM Sans',sans-serif;
    font-size:.9rem; cursor:pointer; margin-top:.6rem; transition:border-color .2s;
  }
  .btn-secondary:hover { border-color:var(--muted); }
  .error-msg { color:var(--danger); font-size:.85rem; margin-bottom:.8rem; display:none; }

  /* ── ADMIN PAGE ── */
  .admin-wrap { max-width:1100px; margin:0 auto; padding:2rem; }
  .admin-header {
    display:flex; align-items:center; justify-content:space-between;
    margin-bottom:2rem; flex-wrap:wrap; gap:1rem;
  }
  .admin-header h2 { font-family:'Syne',sans-serif; font-weight:800; font-size:1.6rem; }
  .btn-logout {
    background:transparent; border:1px solid var(--danger); color:var(--danger);
    padding:.5rem 1.2rem; border-radius:8px; cursor:pointer; font-family:'DM Sans',sans-serif;
    font-size:.9rem; transition:background .2s;
  }
  .btn-logout:hover { background:rgba(248,113,113,.1); }

  .admin-tabs { display:flex; gap:.6rem; margin-bottom:2rem; flex-wrap:wrap; }
  .tab-btn {
    padding:.55rem 1.3rem; border-radius:8px; border:1px solid var(--border);
    background:transparent; color:var(--muted); cursor:pointer;
    font-family:'DM Sans',sans-serif; font-size:.9rem; transition:all .2s;
  }
  .tab-btn.active, .tab-btn:hover { background:var(--accent); border-color:var(--accent); color:#fff; }

  .tab-panel { display:none; }
  .tab-panel.active { display:block; }

  .panel-card {
    background:var(--card); border:1px solid var(--border); border-radius:16px; padding:2rem;
  }
  .panel-card h3 { font-family:'Syne',sans-serif; font-weight:700; margin-bottom:1.5rem; font-size:1.1rem; }

  /* Product list in admin */
  .admin-product-list { display:flex; flex-direction:column; gap:.8rem; }
  .admin-product-item {
    display:flex; align-items:center; gap:1rem;
    background:var(--surface); border:1px solid var(--border); border-radius:10px; padding:1rem;
  }
  .admin-product-item img { width:56px; height:56px; object-fit:cover; border-radius:8px; background:#111; }
  .admin-product-item .info { flex:1; }
  .admin-product-item .info strong { display:block; font-family:'Syne',sans-serif; font-size:.95rem; }
  .admin-product-item .info small { color:var(--muted); font-size:.8rem; }
  .admin-actions { display:flex; gap:.5rem; }
  .btn-edit {
    padding:.4rem .9rem; background:transparent; border:1px solid var(--border);
    color:var(--text); border-radius:7px; cursor:pointer; font-size:.82rem;
    transition:all .2s;
  }
  .btn-edit:hover { border-color:var(--accent2); color:var(--accent2); }
  .btn-del {
    padding:.4rem .9rem; background:transparent; border:1px solid var(--border);
    color:var(--danger); border-radius:7px; cursor:pointer; font-size:.82rem;
    transition:all .2s;
  }
  .btn-del:hover { background:rgba(248,113,113,.1); border-color:var(--danger); }

  /* Logo upload preview */
  .logo-preview {
    width:100px; height:100px; border-radius:12px; background:var(--surface);
    border:2px dashed var(--border); display:flex; align-items:center; justify-content:center;
    overflow:hidden; margin-bottom:1rem; cursor:pointer;
  }
  .logo-preview img { width:100%; height:100%; object-fit:contain; }
  .logo-preview span { color:var(--muted); font-size:.8rem; text-align:center; }
  .header-logo-img { height:36px; object-fit:contain; }

  /* toast */
  .toast {
    position:fixed; bottom:2rem; right:2rem; z-index:999;
    background:var(--success); color:#000; padding:.8rem 1.4rem;
    border-radius:10px; font-weight:600; font-size:.9rem;
    transform:translateY(80px); opacity:0; transition:all .3s;
    pointer-events:none;
  }
  .toast.show { transform:translateY(0); opacity:1; }

  /* img upload area */
  .img-upload-area {
    border:2px dashed var(--border); border-radius:10px; padding:1.5rem;
    text-align:center; color:var(--muted); font-size:.85rem; cursor:pointer;
    transition:border-color .2s; position:relative;
  }
  .img-upload-area:hover { border-color:var(--accent); }
  .img-upload-area input[type=file] {
    position:absolute; inset:0; opacity:0; cursor:pointer;
  }
  .img-preview-thumb {
    width:100%; max-height:160px; object-fit:cover; border-radius:8px; margin-top:.8rem;
    display:none;
  }

  @media(max-width:600px){
    .admin-product-item { flex-wrap:wrap; }
    .admin-actions { width:100%; }
  }
</style>
</head>
<body>

<!-- ════════════════════════ PAGE 1: STOREFRONT ════════════════════════ -->
<div id="page-store" class="page active">

  <header>
    <div class="logo">
      <span class="logo-icon" id="header-logo-icon">🛍️</span>
      <span>Shop<span>Vault</span></span>
      <img id="header-logo-img" class="header-logo-img" src="" style="display:none" alt="logo">
    </div>
  </header>

  <div class="hero">
    <h1>Curated <em>Picks</em> Just for You</h1>
    <p>Hand-selected affiliate products — click to grab the best deals.</p>
  </div>

  <div class="grid-wrap">
    <div class="products-grid" id="products-grid">
      <div class="empty-state">
        <div class="big">📦</div>
        <p>No products yet. Check back soon!</p>
      </div>
    </div>
  </div>

  <div class="login-section">
    <p>Store owner?</p>
    <button class="btn-login-toggle" onclick="openLoginModal()">Admin Login</button>
  </div>

</div>

<!-- ════════════════════════ PAGE 2: ADMIN ════════════════════════ -->
<div id="page-admin" class="page">

  <header>
    <div class="logo">
      <span class="logo-icon" id="admin-logo-icon">🛍️</span>
      <span>Shop<span>Vault</span> <span style="color:var(--muted);font-size:.85rem;font-weight:400">Admin</span></span>
      <img id="admin-logo-img" class="header-logo-img" src="" style="display:none" alt="logo">
    </div>
    <button class="btn-logout" onclick="logout()">Log out</button>
  </header>

  <div class="admin-wrap">
    <div class="admin-header">
      <h2>Dashboard</h2>
    </div>

    <div class="admin-tabs">
      <button class="tab-btn active" onclick="switchTab('tab-products')">📦 Products</button>
      <button class="tab-btn" onclick="switchTab('tab-create')">➕ Create Product</button>
      <button class="tab-btn" onclick="switchTab('tab-settings')">⚙️ Settings</button>
    </div>

    <!-- TAB: Products -->
    <div id="tab-products" class="tab-panel active">
      <div class="panel-card">
        <h3>All Products</h3>
        <div class="admin-product-list" id="admin-product-list">
          <p style="color:var(--muted);font-size:.9rem">No products yet. Create your first one →</p>
        </div>
      </div>
    </div>

    <!-- TAB: Create -->
    <div id="tab-create" class="tab-panel">
      <div class="panel-card">
        <h3 id="create-panel-title">➕ Create New Product</h3>
        <input type="hidden" id="edit-product-id" value="">

        <div class="field">
          <label>Product Name</label>
          <input type="text" id="p-name" placeholder="e.g. Wireless Earbuds Pro">
        </div>
        <div class="field">
          <label>Affiliate Link (URL)</label>
          <input type="text" id="p-link" placeholder="https://...">
        </div>
        <div class="field">
          <label>Description</label>
          <textarea id="p-desc" placeholder="Short product description..."></textarea>
        </div>
        <div class="field">
          <label>Product Image</label>
          <div class="img-upload-area" id="img-upload-area">
            <span>📷 Click to upload image (or paste URL below)</span>
            <input type="file" id="p-img-file" accept="image/*" onchange="handleImgUpload(event)">
            <img id="img-preview-thumb" class="img-preview-thumb" alt="preview">
          </div>
          <input type="text" id="p-img-url" placeholder="Or paste image URL here..." oninput="previewImgUrl()" style="margin-top:.5rem">
        </div>

        <div style="display:flex;gap:.7rem;margin-top:.5rem">
          <button class="btn-primary" style="flex:1" onclick="saveProduct()">💾 Save Product</button>
          <button class="btn-secondary" style="width:auto;padding:.7rem 1.4rem" onclick="clearCreateForm()">Clear</button>
        </div>
      </div>
    </div>

    <!-- TAB: Settings -->
    <div id="tab-settings" class="tab-panel">
      <div class="panel-card" style="margin-bottom:1.5rem">
        <h3>🔑 Change Credentials</h3>
        <div class="field">
          <label>New Username</label>
          <input type="text" id="new-username" placeholder="Enter new username">
        </div>
        <div class="field">
          <label>New Password</label>
          <input type="password" id="new-password" placeholder="Enter new password">
        </div>
        <div class="field">
          <label>Confirm Password</label>
          <input type="password" id="confirm-password" placeholder="Repeat new password">
        </div>
        <button class="btn-primary" onclick="changeCredentials()">Update Credentials</button>
      </div>

      <div class="panel-card">
        <h3>🖼️ Store Logo</h3>
        <div class="logo-preview" id="logo-preview-box" onclick="document.getElementById('logo-file').click()">
          <span>Click to upload logo</span>
        </div>
        <input type="file" id="logo-file" accept="image/*" style="display:none" onchange="handleLogoUpload(event)">
        <p style="color:var(--muted);font-size:.82rem;margin-top:.3rem">Recommended: square image, min 100×100px</p>
        <button class="btn-primary" style="margin-top:1rem" onclick="saveLogo()">💾 Save Logo</button>
      </div>
    </div>

  </div>
</div>

<!-- ════════════════════════ LOGIN MODAL ════════════════════════ -->
<div class="modal-overlay" id="login-modal">
  <div class="modal">
    <h2>Admin <span>Login</span></h2>
    <div class="error-msg" id="login-error">❌ Incorrect username or password.</div>
    <div class="field">
      <label>Username</label>
      <input type="text" id="login-user" placeholder="Enter username" onkeydown="if(event.key==='Enter')doLogin()">
    </div>
    <div class="field">
      <label>Password</label>
      <input type="password" id="login-pass" placeholder="Enter password" onkeydown="if(event.key==='Enter')doLogin()">
    </div>
    <button class="btn-primary" onclick="doLogin()">🔓 Login</button>
    <button class="btn-secondary" onclick="closeLoginModal()">Cancel</button>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<script>
// ══════════════════════════════════════
//  STATE (persisted via localStorage)
// ══════════════════════════════════════
const STORE_KEY = 'shopvault_data';

function loadStore() {
  try { return JSON.parse(localStorage.getItem(STORE_KEY)) || defaultStore(); }
  catch { return defaultStore(); }
}
function saveStore(data) { localStorage.setItem(STORE_KEY, JSON.stringify(data)); }
function defaultStore() {
  return {
    username: 'shy@ms@i',
    password: 'shy@ms@i11499',
    products: [],
    logo: null
  };
}

let store = loadStore();

// ══════════════════════════════════════
//  INIT
// ══════════════════════════════════════
window.addEventListener('DOMContentLoaded', () => {
  applyLogo();
  renderProducts();
});

// ══════════════════════════════════════
//  PAGES
// ══════════════════════════════════════
function showPage(id) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

// ══════════════════════════════════════
//  LOGIN / LOGOUT
// ══════════════════════════════════════
function openLoginModal() {
  document.getElementById('login-modal').classList.add('open');
  document.getElementById('login-user').value = '';
  document.getElementById('login-pass').value = '';
  document.getElementById('login-error').style.display = 'none';
  setTimeout(() => document.getElementById('login-user').focus(), 100);
}
function closeLoginModal() {
  document.getElementById('login-modal').classList.remove('open');
}
function doLogin() {
  const u = document.getElementById('login-user').value.trim();
  const p = document.getElementById('login-pass').value;
  store = loadStore();
  if (u === store.username && p === store.password) {
    closeLoginModal();
    showPage('page-admin');
    renderAdminProducts();
    updateSettingsFields();
  } else {
    document.getElementById('login-error').style.display = 'block';
  }
}
function logout() {
  showPage('page-store');
}

// ══════════════════════════════════════
//  TABS
// ══════════════════════════════════════
function switchTab(id) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  event.currentTarget.classList.add('active');
  if (id === 'tab-products') renderAdminProducts();
}

// ══════════════════════════════════════
//  PRODUCTS
// ══════════════════════════════════════
let imgBase64 = null;

function handleImgUpload(e) {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = ev => {
    imgBase64 = ev.target.result;
    const thumb = document.getElementById('img-preview-thumb');
    thumb.src = imgBase64;
    thumb.style.display = 'block';
    document.getElementById('p-img-url').value = '';
  };
  reader.readAsDataURL(file);
}

function previewImgUrl() {
  const url = document.getElementById('p-img-url').value.trim();
  const thumb = document.getElementById('img-preview-thumb');
  if (url) {
    imgBase64 = null;
    thumb.src = url;
    thumb.style.display = 'block';
  } else {
    thumb.style.display = 'none';
  }
}

function getProductImage() {
  if (imgBase64) return imgBase64;
  const url = document.getElementById('p-img-url').value.trim();
  return url || null;
}

function saveProduct() {
  const name = document.getElementById('p-name').value.trim();
  const link = document.getElementById('p-link').value.trim();
  const desc = document.getElementById('p-desc').value.trim();
  const img = getProductImage();
  const editId = document.getElementById('edit-product-id').value;

  if (!name || !link) { toast('⚠️ Name and link are required!', '#f87171'); return; }

  store = loadStore();

  if (editId) {
    const idx = store.products.findIndex(p => p.id == editId);
    if (idx > -1) {
      store.products[idx] = { ...store.products[idx], name, link, desc, img };
    }
    toast('✅ Product updated!');
  } else {
    store.products.push({ id: Date.now(), name, link, desc, img });
    toast('🎉 Product created!');
  }

  saveStore(store);
  renderProducts();
  renderAdminProducts();
  clearCreateForm();
  switchTab('tab-products');
  document.querySelectorAll('.tab-btn')[0].classList.add('active');
  document.querySelectorAll('.tab-btn')[1].classList.remove('active');
}

function clearCreateForm() {
  document.getElementById('p-name').value = '';
  document.getElementById('p-link').value = '';
  document.getElementById('p-desc').value = '';
  document.getElementById('p-img-url').value = '';
  document.getElementById('p-img-file').value = '';
  document.getElementById('img-preview-thumb').style.display = 'none';
  document.getElementById('edit-product-id').value = '';
  document.getElementById('create-panel-title').textContent = '➕ Create New Product';
  imgBase64 = null;
}

function editProduct(id) {
  store = loadStore();
  const p = store.products.find(p => p.id == id);
  if (!p) return;
  document.getElementById('p-name').value = p.name;
  document.getElementById('p-link').value = p.link;
  document.getElementById('p-desc').value = p.desc || '';
  document.getElementById('p-img-url').value = (p.img && !p.img.startsWith('data:')) ? p.img : '';
  document.getElementById('edit-product-id').value = id;
  document.getElementById('create-panel-title').textContent = '✏️ Edit Product';
  imgBase64 = (p.img && p.img.startsWith('data:')) ? p.img : null;
  const thumb = document.getElementById('img-preview-thumb');
  if (p.img) { thumb.src = p.img; thumb.style.display = 'block'; } else { thumb.style.display = 'none'; }
  // switch to create tab
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-create').classList.add('active');
  document.querySelectorAll('.tab-btn')[1].classList.add('active');
}

function deleteProduct(id) {
  if (!confirm('Delete this product?')) return;
  store = loadStore();
  store.products = store.products.filter(p => p.id != id);
  saveStore(store);
  renderProducts();
  renderAdminProducts();
  toast('🗑️ Product deleted.');
}

function renderProducts() {
  store = loadStore();
  const grid = document.getElementById('products-grid');
  if (!store.products.length) {
    grid.innerHTML = `<div class="empty-state"><div class="big">📦</div><p>No products yet. Check back soon!</p></div>`;
    return;
  }
  grid.innerHTML = store.products.map(p => `
    <div class="product-card">
      <div class="product-img-wrap">
        ${p.img
          ? `<img src="${p.img}" alt="${p.name}" onerror="this.parentNode.innerHTML='<div class=no-img><span class=icon>🖼️</span><span>Image unavailable</span></div>'">`
          : `<div class="no-img"><span class="icon">🖼️</span><span>No image</span></div>`}
      </div>
      <div class="product-body">
        <div class="product-name">${p.name}</div>
        ${p.desc ? `<div class="product-desc">${p.desc}</div>` : ''}
        <a class="btn-open" href="${p.link}" target="_blank" rel="noopener">Open Deal →</a>
      </div>
    </div>
  `).join('');
}

function renderAdminProducts() {
  store = loadStore();
  const list = document.getElementById('admin-product-list');
  if (!store.products.length) {
    list.innerHTML = `<p style="color:var(--muted);font-size:.9rem">No products yet. Create your first one →</p>`;
    return;
  }
  list.innerHTML = store.products.map(p => `
    <div class="admin-product-item">
      ${p.img
        ? `<img src="${p.img}" alt="${p.name}" onerror="this.src=''">`
        : `<div style="width:56px;height:56px;background:var(--border);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:1.4rem">📦</div>`}
      <div class="info">
        <strong>${p.name}</strong>
        <small>${p.link.length > 40 ? p.link.slice(0,40)+'…' : p.link}</small>
      </div>
      <div class="admin-actions">
        <button class="btn-edit" onclick="editProduct(${p.id})">✏️ Edit</button>
        <button class="btn-del" onclick="deleteProduct(${p.id})">🗑️ Delete</button>
      </div>
    </div>
  `).join('');
}

// ══════════════════════════════════════
//  SETTINGS
// ══════════════════════════════════════
function updateSettingsFields() {
  store = loadStore();
  document.getElementById('new-username').value = store.username;
}

function changeCredentials() {
  const u = document.getElementById('new-username').value.trim();
  const p = document.getElementById('new-password').value;
  const c = document.getElementById('confirm-password').value;
  if (!u) { toast('⚠️ Username cannot be empty.', '#f87171'); return; }
  if (p && p !== c) { toast('⚠️ Passwords do not match.', '#f87171'); return; }
  store = loadStore();
  store.username = u;
  if (p) store.password = p;
  saveStore(store);
  document.getElementById('new-password').value = '';
  document.getElementById('confirm-password').value = '';
  toast('✅ Credentials updated!');
}

// ── LOGO ──
let logoBase64 = null;
function handleLogoUpload(e) {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = ev => {
    logoBase64 = ev.target.result;
    const box = document.getElementById('logo-preview-box');
    box.innerHTML = `<img src="${logoBase64}" alt="logo">`;
  };
  reader.readAsDataURL(file);
}
function saveLogo() {
  if (!logoBase64) { toast('⚠️ Please upload a logo first.', '#f87171'); return; }
  store = loadStore();
  store.logo = logoBase64;
  saveStore(store);
  applyLogo();
  toast('✅ Logo saved!');
}
function applyLogo() {
  store = loadStore();
  if (!store.logo) return;
  // Store header
  const storeIcon = document.getElementById('header-logo-icon');
  const storeImg = document.getElementById('header-logo-img');
  storeIcon.style.display = 'none';
  storeImg.src = store.logo;
  storeImg.style.display = 'block';
  // Admin header
  const adminIcon = document.getElementById('admin-logo-icon');
  const adminImg = document.getElementById('admin-logo-img');
  adminIcon.style.display = 'none';
  adminImg.src = store.logo;
  adminImg.style.display = 'block';
  // Preview box
  const box = document.getElementById('logo-preview-box');
  if (box) box.innerHTML = `<img src="${store.logo}" alt="logo">`;
  logoBase64 = store.logo;
}

// ══════════════════════════════════════
//  TOAST
// ══════════════════════════════════════
function toast(msg, bg = 'var(--success)') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.style.background = bg;
  t.style.color = bg === 'var(--success)' ? '#000' : '#fff';
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3000);
}
</script>
